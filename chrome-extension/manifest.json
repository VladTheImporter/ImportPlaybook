{
  "manifest_version": 3,
  "name": "ImportPlaybook Scout",
  "version": "0.1.0",
  "description": "Export vehicle data from B-Pro listings into a standardized format.",
  "permissions": [
    "activeTab",
    "downloads",
    "storage"
  ],
  "host_permissions": [
    "https://b-pro.ca/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "ImportPlaybook Scout"
  },
  "content_scripts": [
    {
      "matches": [
        "https://b-pro.ca/*"
      ],
      "js": [
        "content.js"
      ]
    }
  ]
}